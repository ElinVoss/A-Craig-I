# VibeCode Backend Configuration
# Copy to .env for local dev. Set all of these in Render dashboard for production.

# ─── AI ────────────────────────────────────────────────────────────────────
# Gemini API Key (https://makersuite.google.com/app/apikeys)
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Database ──────────────────────────────────────────────────────────────
# Local: postgresql://user:password@localhost:5432/vibecode
# Neon:  postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/vibecode?sslmode=require
# Render: injected automatically from render.yaml
DATABASE_URL=postgresql://vibeCodeUser:vibeCodePassword123@localhost:5432/vibeCode

# ─── JWT Auth ──────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Stripe Billing ────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Get Price IDs from https://dashboard.stripe.com/products after creating products
STRIPE_PRO_PRICE_ID=price_your_pro_price_id
STRIPE_TEAM_PRICE_ID=price_your_team_price_id

# ─── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Set to your Vercel URL in production.
# Example: https://vibecode.vercel.app,https://www.vibecode.dev
FRONTEND_URL=http://localhost:3000

# ─── Server ────────────────────────────────────────────────────────────────
ENVIRONMENT=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

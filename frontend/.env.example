# VibeCode Frontend Environment Variables
# Copy to .env.local for local dev, set in Vercel dashboard for production

# Backend URL — Vercel will call this for all /api/* routes
VITE_API_URL=http://localhost:8000

# Stripe publishable key (safe to expose — used in browser for Checkout redirect)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
